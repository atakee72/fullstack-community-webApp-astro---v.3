---
// Site-wide footer. Year auto-updates each calendar year (evaluated at
// build/SSR time, so prerendered pages get the year frozen at last deploy —
// good enough for a copyright notice).
const year = new Date().getFullYear();
---

<footer class="relative z-10 mt-16 py-6 text-center text-xs text-white/50">
  <p>
    © {year} Ercan Atak — Mahalle. Licensed under
    <a
      href="https://polyformproject.org/licenses/noncommercial/1.0.0"
      class="underline hover:text-white/80"
      target="_blank"
      rel="noopener noreferrer"
    >
      PolyForm Noncommercial 1.0.0
    </a>.
  </p>
</footer>
