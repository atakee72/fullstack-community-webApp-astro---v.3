---
interface Props {
  title: string;
  subtitle?: string;
  color?: string; // hex color for the status bars, defaults to wine
  subtitleClass?: string; // override subtitle text color, defaults to 'text-gray-600'
}

const { title, subtitle, color = '#814256', subtitleClass = 'text-gray-600' } = Astro.props;

const bars = [
  { width: '100%', opacity: 1 },
  { width: '66%', opacity: 0.7 },
  { width: '33%', opacity: 0.4 },
];
---

<div class="page-header pt-6 md:pt-8 mb-8 opacity-0 -translate-y-5 transition-all duration-500" data-page-header>
  <h1 class="text-3xl md:text-4xl font-bold mb-2 font-['Space_Grotesk',sans-serif]" style={`color: ${color}`}>{title}</h1>
  {subtitle && <p class:list={[subtitleClass, 'text-lg']}>{subtitle}</p>}

  <div class="mt-6 space-y-1">
    {bars.map((bar, i) => (
      <div
        class="h-0.5 rounded-full transition-all duration-700 origin-left scale-x-0"
        style={`background: ${color}; opacity: ${bar.opacity}; width: ${bar.width}; transition-delay: ${300 + i * 100}ms`}
        data-header-bar
      />
    ))}
  </div>
</div>

<script is:inline data-astro-rerun>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('[data-page-header]').forEach(function (el) {
        el.classList.remove('opacity-0', '-translate-y-5');
        el.classList.add('opacity-100', 'translate-y-0');
        el.querySelectorAll('[data-header-bar]').forEach(function (bar) {
          bar.classList.remove('scale-x-0');
          bar.classList.add('scale-x-100');
          bar.style.transitionDelay = '0ms';
        });
      });
      return;
    }
    setTimeout(function () {
      document.querySelectorAll('[data-page-header]').forEach(function (el) {
        el.classList.remove('opacity-0', '-translate-y-5');
        el.classList.add('opacity-100', 'translate-y-0');
        el.querySelectorAll('[data-header-bar]').forEach(function (bar) {
          bar.classList.remove('scale-x-0');
          bar.classList.add('scale-x-100');
        });
      });
    }, 100);
  })();
</script>
