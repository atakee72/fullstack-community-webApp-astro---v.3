<!-- Splash/Loader Screen - plays LogoVideo once per session -->
<div id="splash-overlay">
  <video
    id="splash-video"
    src="/LogoVideo.mp4"
    muted
    playsinline
    preload="auto"
    fetchpriority="high"
  ></video>
</div>

<!-- Initial page load: synchronous, runs before first paint -->
<script is:inline data-astro-rerun>
  (function () {
    var overlay = document.getElementById('splash-overlay');
    if (!overlay) return;

    // Main navigation pages — update this list if main pages change
    var splashPages = ['/', '/blog', '/newsboard', '/calendar', '/marketplace', '/profile', '/schillerkiez'];
    var path = window.location.pathname.replace(/\/+$/, '') || '/';
    if (splashPages.indexOf(path) === -1) {
      overlay.remove();
      return;
    }

    // Already shown this session or reduced motion — remove, stay hidden
    try {
      if (
        sessionStorage.getItem('mahalle-splash-shown') ||
        window.matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        overlay.remove();
        return;
      }
    } catch (e) {
      // sessionStorage can throw in privacy modes — fall through and show splash
    }

    // First visit: show overlay fully opaque from the start — no fade-in
    // (fade-in briefly exposes the page bg behind the solid overlay color).
    overlay.style.display = 'flex';
    overlay.style.opacity = '1';

    var dismissed = false;
    var videoReady = false;
    var pageReady = false;
    var video = document.getElementById('splash-video');

    function dismissSplash() {
      if (dismissed) return;
      // Only dismiss when BOTH conditions are met
      if (!videoReady || !pageReady) return;
      dismissed = true;
      try { sessionStorage.setItem('mahalle-splash-shown', '1'); } catch (e) {}

      var anim = overlay.animate(
        [{ opacity: 1 }, { opacity: 0 }],
        { duration: 500, easing: 'ease-out', fill: 'forwards' }
      );
      anim.finished.then(function () {
        overlay.remove();
      });
    }

    function onVideoDone() {
      videoReady = true;
      dismissSplash();
    }

    function onPageLoaded() {
      pageReady = true;
      dismissSplash();
    }

    // --- Video done detection ---
    if (video) {
      // Reveal the video element only once its first frame is decoded,
      // so users don't see an empty blob-shaped placeholder while loading.
      video.addEventListener('loadeddata', function () {
        video.classList.add('ready');
      });
      // If autoplay is blocked (common on mobile Firefox even with muted),
      // dismiss quickly rather than leaving a blank overlay sitting there.
      video.play().catch(function () {
        setTimeout(function () {
          videoReady = true;
          pageReady = true;
          dismissSplash();
        }, 600);
      });
      video.addEventListener('ended', onVideoDone);

      // Backup: check via timeupdate if video reached the end
      video.addEventListener('timeupdate', function () {
        if (video.currentTime >= video.duration - 0.1) {
          onVideoDone();
        }
      });
    } else {
      videoReady = true;
    }

    // --- Page load detection ---
    if (document.readyState === 'complete') {
      pageReady = true;
    } else {
      window.addEventListener('load', onPageLoaded);
    }

    // Safety timeout — dismiss after 4s no matter what
    setTimeout(function () {
      if (document.getElementById('splash-overlay')) {
        videoReady = true;
        pageReady = true;
        dismissSplash();
      }
    }, 4000);
  })();
</script>

