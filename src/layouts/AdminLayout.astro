---
// Editorial Kiosk layout for the internal admin moderation back-office.
// Sibling to AuthLayout, but for the OPPOSITE audience: a logged-in admin,
// not a logged-out visitor. No KioskNav (this isn't part of the public app
// nav), no footer. Plum accent via [data-page="admin"] in tokens.css.
// Session-independent by design — the page (moderation.astro) resolves
// getSession and passes only what the masthead needs (adminName).
import AuthLangToggle from '../components/auth/kiosk/AuthLangToggle.svelte';
import ToastProvider from '../components/ToastProvider';
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  adminName?: string;
}

const { title, adminName = '' } = Astro.props;

const trimmedAdminName = adminName.trim();
const adminInitial = (trimmedAdminName[0] ?? '?').toUpperCase();
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Mahalle — interne Moderationsoberfläche." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>

  <body
    class="min-h-screen k-paper-bg text-ink font-bricolage antialiased flex flex-col"
    data-page="admin"
  >
    <!-- ═══ Desktop (≥ md) masthead — full ribbon + branding + back-link. ═══ -->
    <div class="hidden md:block">
      <!-- Internal-area ribbon — static DE, locked decision (Task 1 brief). -->
      <div
        class="flex items-center justify-between font-dmmono"
        style="background:var(--k-accent); color:var(--k-paper); padding:6px 36px; font-size:10px; letter-spacing:0.14em;"
      >
        <span>INTERNER BEREICH — NUR FÜR ADMINS SICHTBAR</span>
        <span>user.role === "admin"</span>
      </div>

      <header
        class="flex items-center justify-between"
        style="padding:18px 36px; border-bottom:1px dashed var(--k-rule);"
      >
        <div class="flex items-center" style="gap:12px;">
          <div
            class="font-instrument"
            style="width:42px; height:42px; background:var(--k-accent); border-radius:50%; border:2px solid var(--k-ink); display:flex; align-items:center; justify-content:center; font-style:italic; font-size:26px; color:var(--k-paper);"
          >m</div>
          <div>
            <div class="font-bricolage" style="font-size:22px; font-weight:800; letter-spacing:-0.03em; line-height:1;">
              mahalle <span class="font-instrument" style="font-style:italic; font-weight:400; color:var(--k-accent);">moderation</span>
            </div>
            <div class="font-dmmono" style="font-size:9px; color:var(--k-ink-mute); letter-spacing:0.1em; margin-top:2px;">SCHILLERKIEZ · NEUKÖLLN · ADMIN</div>
          </div>
        </div>

        <div class="flex items-center" style="gap:14px;">
          <a href="/forum" class="font-dmmono no-underline" style="font-size:11px; color:var(--k-ink-mute);">← zurück zum Forum</a>
          <AuthLangToggle client:load />
          <div
            class="font-bricolage"
            style="width:38px; height:38px; background:var(--k-accent); border-radius:50%; border:2px solid var(--k-ink); display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px; color:var(--k-paper);"
            aria-label={`Angemeldet als ${trimmedAdminName || 'Admin'}`}
          >{adminInitial}</div>
        </div>
      </header>
    </div>

    <!-- ═══ Mobile (< md) masthead — slim ribbon + compact wordmark. ═══
         Per JSX kiosk-admin.jsx:482-491. No back-link, no avatar — those
         are desktop-only chrome; AuthLangToggle stays available (moved
         into this row) so DE/EN swap still works on mobile. -->
    <div class="md:hidden">
      <div
        class="font-dmmono"
        style="background:var(--k-accent); color:var(--k-paper); padding:6px 18px; font-size:9px; letter-spacing:0.12em;"
      >INTERN · NUR ADMIN</div>

      <header
        class="flex items-center justify-between"
        style="padding:14px 18px; border-bottom:1px dashed var(--k-rule);"
      >
        <div class="flex items-center" style="gap:9px;">
          <div
            class="font-instrument"
            style="width:32px; height:32px; background:var(--k-accent); border-radius:50%; border:2px solid var(--k-ink); display:flex; align-items:center; justify-content:center; font-style:italic; font-size:19px; color:var(--k-paper);"
          >m</div>
          <div class="font-bricolage" style="font-size:17px; font-weight:800; letter-spacing:-0.02em;">moderation</div>
        </div>

        <AuthLangToggle client:load />
      </header>
    </div>

    <main class="flex-1">
      <slot />
    </main>
    <ToastProvider client:load />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/admin.css';
</style>
