---
// /topics/create — Editorial Kiosk compose page.
//
// Auth-gated by frontmatter: redirect to /login when there is no
// session. Same pattern as /admin/moderation. The form's submit also
// re-checks server-side via /api/topics/create's 401 handler.

import KioskLayout from '../../layouts/KioskLayout.astro';
import ComposePage from '../../components/forum/kiosk/compose/ComposePage.svelte';
import { getSession } from 'auth-astro/server';
import { isUserBanned } from '../../lib/auth/banGuard';

const session = await getSession(Astro.request);

if (!session?.user) {
  return Astro.redirect('/login', 302);
}

// Ban enforcement: banned accounts are read-only — no compose surfaces.
// The SuspendedBanner on the target page explains why.
if (await isUserBanned(session.user.id)) {
  return Astro.redirect('/', 302);
}

const currentUser = {
  id: session.user.id,
  name: session.user.name ?? undefined,
  image: session.user.image ?? null
};
---

<KioskLayout title="Mahalle · neues Thema" description="Schreibe einen neuen Beitrag im Mahalle-Forum." page="forum">
  <ComposePage client:only="svelte" currentUser={currentUser} />
</KioskLayout>
