---
import KioskLayout from '../../layouts/KioskLayout.astro';
import { getSession } from 'auth-astro/server';
import { fetchListingsForSSR, type ListingsFetchInput } from '../../lib/listingsQuery';
import MarketplaceBrowseInner from '../../components/marketplace/kiosk/browse/MarketplaceBrowseInner.svelte';

// Cache-control: per-user moderation visibility makes caching unsafe.
Astro.response.headers.set('Cache-Control', 'no-store, must-revalidate');

const session = await getSession(Astro.request);
const userId = (session?.user as any)?.id ?? null;

// URL param → kind key mapping (rail DE keys → API keys)
const RAIL_TO_API: Record<string, string> = {
  verkaufen: 'sell',
  tausch: 'exchange',
  verschenken: 'gift',
};

// Parse SSR filter input from URL params for first-paint hydration.
const url = Astro.url;
const railKind = url.searchParams.get('kind') ?? 'all';
const ssrInput: ListingsFetchInput = {
  kind: (RAIL_TO_API[railKind] ?? railKind) as any,
  category: url.searchParams.get('cat') ?? 'all',
  search: url.searchParams.get('q') ?? undefined,
  view: (url.searchParams.get('view') as any) ?? null,
  limit: 24,
  offset: Number(url.searchParams.get('page') ?? 0) * 24,
};

const initialData = await fetchListingsForSSR(ssrInput, userId);
---

<KioskLayout title="Markt — Mahalle" description="Stöbern im Kiez-Markt." page="marketplace">
  <MarketplaceBrowseInner
    client:only="svelte"
    initialData={initialData}
    currentUserId={userId}
  />
</KioskLayout>
