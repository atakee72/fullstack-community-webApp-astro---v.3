---
import KioskLayout from '../../../layouts/KioskLayout.astro';
import { getSession } from 'auth-astro/server';
import { fetchListingForSSR } from '../../../lib/listingsQuery';
import MarketComposeInner from '../../../components/marketplace/kiosk/compose/MarketComposeInner.svelte';

const session = await getSession(Astro.request);
if (!session?.user) {
  return Astro.redirect(`/login?redirect=/marketplace/edit/${Astro.params.id}`);
}
const userId = (session.user as any).id;

const { id } = Astro.params;
if (!id) return Astro.redirect('/marketplace?not_found=1');

const listing = await fetchListingForSSR(id, userId);
if (!listing) return Astro.redirect('/marketplace?not_found=1');

// Owner gate
if (String(listing.sellerId) !== userId) return Astro.redirect('/marketplace?not_owner=1');

// Moderation gate — only `pending` is blocked here (mid-moderation, any edit
// would race the server-side flow). Rejected + warning-labeled listings are
// allowed through: the edit endpoint re-runs full moderation, writes a
// pre-edit audit snapshot (listingAuditTrail), and auto-clears the warning
// or rejection on clean re-mod. Reserved/sold reach the form (existing
// behavior); the API 409s at submit. See plan
// /home/atakee/.claude/plans/mighty-pondering-dawn.md.
if (listing.moderationStatus === 'pending') {
  return Astro.redirect('/marketplace?edit_blocked=1');
}
---

<KioskLayout page="marketplace" title="Anzeige bearbeiten · Mahalle Markt">
  <MarketComposeInner
    client:only="svelte"
    mode="edit"
    initialListing={listing}
    currentUserId={userId}
  />
</KioskLayout>
