---
import KioskLayout from '../../../layouts/KioskLayout.astro';
import { getSession } from 'auth-astro/server';
import { fetchListingForSSR } from '../../../lib/listingsQuery';
import MarketComposeInner from '../../../components/marketplace/kiosk/compose/MarketComposeInner.svelte';

const session = await getSession(Astro.request);
if (!session?.user) {
  return Astro.redirect(`/login?redirect=/marketplace/edit/${Astro.params.id}`);
}
const userId = (session.user as any).id;

const { id } = Astro.params;
if (!id) return Astro.redirect('/marketplace?not_found=1');

const listing = await fetchListingForSSR(id, userId);
if (!listing) return Astro.redirect('/marketplace?not_found=1');

// Owner gate
if (String(listing.sellerId) !== userId) return Astro.redirect('/marketplace?not_owner=1');

// Page gate mirrors canMutateListing's effective behavior for edit (which
// passes { allowOnRejected, allowOnWarningLabel } — i.e. only blocks pending,
// reserved, sold). Without these short-circuits the user could fill in the
// compose form for a reserved/sold listing only to have the API 409 at submit.
// - pending → mid-moderation, server-side flow in flight
// - reserved/sold → trade state; use the status endpoint to leave those first
// Rejected + warning-labeled listings still pass through: the edit endpoint
// re-runs full moderation, writes a pre-edit audit snapshot (listingAuditTrail),
// and auto-clears the warning/rejection on clean re-mod.
if (
  listing.moderationStatus === 'pending' ||
  listing.status === 'reserved' ||
  listing.status === 'sold'
) {
  return Astro.redirect('/marketplace?edit_blocked=1');
}
---

<KioskLayout page="marketplace" title="Anzeige bearbeiten · Mahalle Markt">
  <MarketComposeInner
    client:only="svelte"
    mode="edit"
    initialListing={listing}
    currentUserId={userId}
  />
</KioskLayout>
