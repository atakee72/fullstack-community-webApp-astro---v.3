---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import UserProfileWrapper from '../components/UserProfileWrapper';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
---

<BaseLayout title="User Profile">
  <main class="min-h-[calc(100vh-80px)] bg-gradient-to-br from-[#eccc6e] to-[#dabb5d] py-8">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <PageHeader title="Your Profile" />
    </div>
    <UserProfileWrapper client:load user={session?.user} />
  </main>
</BaseLayout>