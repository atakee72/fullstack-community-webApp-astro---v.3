---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { getSession } from 'auth-astro/server';
import ForumWrapper from '../components/ForumWrapper';

const session = await getSession(Astro.request);
---

<BaseLayout title="Your Local Forum">
  <div class="dark-glass-bg" aria-hidden="true"></div>
  <div class="dark-glass-gradient" aria-hidden="true"></div>

  <main class="relative z-10 min-h-[calc(100vh-60px)] py-2 md:py-4 font-inter carved-title" style="--carved-accent: #6F2F59">
    <div class="max-w-7xl mx-auto px-4 md:px-8 lg:px-16">
      <PageHeader title="Your Local Forum" color="#6F2F59" subtitleClass="text-white/70" />
      <div class="bg-white/[0.06] border border-white/[0.15] border-t-white/30 border-l-white/25 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1)] flex justify-center px-2 sm:px-4 md:px-8 lg:px-12 py-6 md:py-8 rounded-lg mt-1 md:mt-2 min-h-[400px]">
        <ForumWrapper client:only="react" session={session} />
      </div>
    </div>
  </main>
  <footer class="relative z-10 text-white/60 text-center py-4 md:py-6 mt-auto">
    <p class="text-sm md:text-base">&copy; 2023 Mahalle Community App. All rights reserved.</p>
  </footer>
</BaseLayout>
