---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { getSession } from 'auth-astro/server';
import ForumWrapper from '../components/ForumWrapper';

const session = await getSession(Astro.request);
---

<BaseLayout title="Your Local Forum">
  <main class="min-h-[calc(100vh-60px)] py-2 md:py-4">
    <div class="max-w-7xl mx-auto px-4 md:px-8 lg:px-16">
      <PageHeader title="Your Local Forum" />
      <div class="bg-[#4b9aaa] flex justify-center px-2 sm:px-4 md:px-8 lg:px-12 py-6 md:py-8 rounded-lg mt-1 md:mt-2 min-h-[400px]">
        <ForumWrapper client:only="react" session={session} />
      </div>
    </div>
  </main>
  <footer class="bg-gray-800 text-white text-center py-4 md:py-6 mt-auto">
    <p class="text-sm md:text-base">&copy; 2023 Mahalle Community App. All rights reserved.</p>
  </footer>
</BaseLayout>