      <p class="font-bricolage text-sm text-ink-soft mb-6 max-w-2xl">
        The full compose form — title, type selector, body editor, image
        upload, tag input. Used by both <code class="font-dmmono text-[12px]">/topics/create</code> and (in a different
        layout) inline edit on the post detail page. Below: a live form
        instance — interact with it to see the type selector toggle and
        char counters update.
      </p>
      <div class="border-2 border-ink rounded-lg overflow-hidden bg-paper">
        <ComposeForm
          suggestedTags={['nachbarschaft', 'upcycling', 'sonntag']}
          onChange={() => {}}
          client:load
        />
      </div>
    </section>

    {/* ── 19 · ComposePreview ──────────────────────────────────────── */}
    <section class="mb-12">
      <h2 class="font-dmmono text-xs uppercase tracking-[0.18em] text-ink-mute mb-2">
        19 · ComposePreview — live preview sidebar
