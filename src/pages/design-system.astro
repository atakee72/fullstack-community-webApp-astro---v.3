          kind="discussion"
          ghosted
          statusBadgeOverride="flagged"
          client:load
        />
        <ForumPostCard topic={recommendationSample} kind="recommendation" client:load />
        <ForumPostCard topic={announcementSample} kind="announcement" team client:load />
      </div>
    </section>

    {/* ── 16 · Rate-limit panel ────────────────────────────────────── */}
    <section class="mb-12">
      <h2 class="font-dmmono text-xs uppercase tracking-[0.18em] text-ink-mute mb-2">
        16 · Rate-limit panel
