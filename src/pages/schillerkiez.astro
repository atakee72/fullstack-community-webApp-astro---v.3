---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import KiezDashboard from '../components/kiez/KiezDashboard.svelte';
---

<BaseLayout
  title="Schillerkiez in Zahlen - Mahalle"
  description="Demografische und soziale Daten aus dem Schillerkiez in Berlin-Neukölln"
>
  <div class="dark-glass-bg" aria-hidden="true"></div>
  <div class="dark-glass-gradient" aria-hidden="true"></div>

  <div class="relative z-10 min-h-[calc(100vh-60px)] py-2 md:py-3 font-inter carved-title" style="--carved-accent: #5cb87a">
    <div class="max-w-7xl mx-auto px-4 md:px-8 lg:px-12">
      <PageHeader
        title="Schillerkiez in Zahlen"
        subtitle="Demografie, Soziales & Umwelt aus dem Herzen Neuköllns"
        color="#5cb87a"
        subtitleClass="text-white/70"
      />
      <KiezDashboard client:load />
    </div>
  </div>
</BaseLayout>
