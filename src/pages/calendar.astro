---
import KioskLayout from '../layouts/KioskLayout.astro';
import { getSession } from 'auth-astro/server';
import CalendarPage from '../components/calendar/kiosk/CalendarPage.svelte';
import { fetchEventsForSSR } from '../lib/eventsQuery';

const session = await getSession(Astro.request);

let initialEvents: any[] = [];
try {
  initialEvents = await fetchEventsForSSR(session?.user?.id);
} catch (err) {
  console.error('[calendar.astro] SSR events prefetch failed:', err);
}
---

<KioskLayout title="Kalender">
  <CalendarPage
    client:only="svelte"
    initialEvents={initialEvents}
    currentUserId={session?.user?.id ?? null}
  />
</KioskLayout>
