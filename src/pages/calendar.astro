---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { getSession } from 'auth-astro/server';
import CalendarWrapper from '../components/CalendarWrapper';

const session = await getSession(Astro.request);
---

<BaseLayout title="Neighbourhood Calendar - Mahalle">
  <div class="dark-glass-bg" aria-hidden="true"></div>
  <div class="dark-glass-gradient" aria-hidden="true"></div>

  <main class="relative z-10 min-h-[calc(100vh-60px)] py-2 md:py-3 font-inter carved-title" style="--carved-accent: #d4af37">
    <div class="max-w-7xl mx-auto px-1 min-[350px]:px-5 min-[500px]:px-7 min-[700px]:px-8 md:px-9 lg:px-16">
      <PageHeader
        title="Neighbourhood Calendar"
        subtitle="Community events and gatherings in your neighbourhood"
        color="#d4af37"
        subtitleClass="text-white/70"
      />
      <CalendarWrapper client:load session={session} />
    </div>
  </main>
</BaseLayout>
